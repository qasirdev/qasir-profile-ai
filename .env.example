# OpenRouter API Key for AI Digital Twin
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Primary model and comma-separated fallback chain (OpenRouter route=fallback)
LLM_PRIMARY_MODEL=openai/gpt-oss-120b:free
LLM_OPENROUTER_MODELS=openai/gpt-oss-120b:free,deepseek/deepseek-v4-flash,openai/gpt-oss-120b

# Digital Twin question quotas (0 = unlimited for that window)
DIGITAL_TWIN_MAX_QUESTIONS_PER_VISIT=5
DIGITAL_TWIN_MAX_QUESTIONS_PER_DAY=20

# Optional: cap conversation history sent to model (token savings)
DIGITAL_TWIN_MAX_HISTORY_TURNS=6

# Optional: HMAC secret for signed quota cookies (defaults to OPENROUTER_API_KEY)
# DIGITAL_TWIN_QUOTA_SECRET=your_quota_signing_secret

# Chatbase embed (free tier: widget only, 50 credits/month account-wide)
# Train the agent in Chatbase dashboard using content from src/lib/digital-twin-knowledge.ts
NEXT_PUBLIC_CHATBASE_EMBED_ID=your_chatbase_agent_id

# Provider control: auto | chatbase | openrouter
NEXT_PUBLIC_DIGITAL_TWIN_FORCE_PROVIDER=auto

# Optional: proactive switch threshold for mirror counter (best-effort per browser)
DIGITAL_TWIN_CHATBASE_MONTHLY_BUDGET=50

# Microsoft Clarity Analytics
NEXT_PUBLIC_CLARITY_PROJECT_ID=your_clarity_project_id_here

# Next.js Configuration
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Profile photo from LinkedIn (defaults to /profile-photo.jpg in public/)
# NEXT_PUBLIC_PROFILE_IMAGE_URL=/profile-photo.jpg

# CV download (GitHub raw PDF — update file in repo without redeploying the site)
NEXT_PUBLIC_CV_URL=https://github.com/qasirdev/qasir-profile-ai/raw/main/cv/qasir-mehmood-cv.pdf

# Plain-text resume (GitHub raw markdown — fetched at runtime, revalidates hourly)
NEXT_PUBLIC_RESUME_TEXT_URL=https://github.com/qasirdev/qasir-profile-ai/raw/main/cv/qasir-fullstack-cv.md

# Sanity CMS — blog content at /blogs, Studio at /studio (see docs/SANITY_SETUP_GUIDE.md)
NEXT_PUBLIC_SANITY_PROJECT_ID=your_sanity_project_id
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SANITY_API_VERSION=2026-06-01
# Optional: preview/draft access (server-side only — never expose in client code)
SANITY_API_TOKEN=your_sanity_api_token
